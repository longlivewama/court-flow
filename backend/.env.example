# ─── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# ─── PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://courtflow:courtflow_pass@localhost:5432/courtflow
DATABASE_URL_AUDIT=postgresql://audit_writer:CHANGE_IN_PRODUCTION@localhost:5432/courtflow

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT / Auth ─────────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=change_this_to_a_long_random_string_in_production

# ─── Encryption (AES-256-GCM for receipts) ──────────────────
ENCRYPTION_KEY=change_to_32_byte_hex_encoded_key_in_production

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@courtflow.example.com
SMTP_PASS=change_in_production
EMAIL_FROM="CourtFlow <noreply@courtflow.example.com>"

# ─── File Storage ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_WINDOW_MS=60000

# ─── WhatsApp (Meta Cloud API, outbound confirmations only) ─
WHATSAPP_ACCESS_TOKEN=change_in_production
WHATSAPP_PHONE_NUMBER_ID=change_in_production
WHATSAPP_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=20

# ─── Google Sheets (per-club backup ledger sync) ─────────────
# Service-account credentials; share each club's ledger sheet with this email.
# The spreadsheet ID itself lives per club in clubs.sheets_spreadsheet_id.
GOOGLE_SHEETS_CLIENT_EMAIL=ledger-sync@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_IN_PRODUCTION\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_TAB=Bookings

# ─── Club ───────────────────────────────────────────────────
CLUB_ID=00000000-0000-0000-0000-000000000001
FRONTEND_URL=http://localhost:3000
